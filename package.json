{
  "name": "gitmesh",
  "version": "0.1.14",
  "description": "Agent 并行编码时的 git 管道工 — 在单仓库内为多个 Agent 创建隔离 worktree，自动将变更合回主干",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "worktree",
    "agent",
    "merge",
    "orchestration"
  ],
  "license": "MIT",
  "author": "neil-ji",
  "homepage": "https://neil-ji.github.io/git-mesh/",
  "bugs": {
    "url": "https://github.com/neil-ji/git-mesh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neil-ji/git-mesh.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "provenance": "true"
  }
}

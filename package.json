{
  "name": "gitmesh",
  "version": "0.1.18",
  "description": "Git worktree orchestration for parallel AI coding agents — isolated worktrees, auto rebase-merge, and smart conflict routing. 多 Agent 并行编码的 Git 编排层。",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "worktree",
    "agent",
    "merge",
    "orchestration",
    "git-worktree",
    "ai-agent",
    "parallel",
    "conflict-resolution",
    "rebase",
    "multi-agent",
    "typescript",
    "coding-agent",
    "automation",
    "git-workflow",
    "agentic",
    "ai-coding",
    "merge-orchestration"
  ],
  "license": "MIT",
  "author": "neil-ji",
  "homepage": "https://neil-ji.github.io/git-mesh/",
  "bugs": {
    "url": "https://github.com/neil-ji/git-mesh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neil-ji/git-mesh.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "simple-git": "^3.36.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "provenance": "true"
  }
}
